# Twitter API v2 — get a Bearer Token at developer.twitter.com
TWITTER_BEARER_TOKEN=your_bearer_token_here

# Optional: protect this local API with a key (leave blank to disable auth)
API_KEY=

# Port (default: 3030)
PORT=3030

# Requests per minute per IP / API key (default: 60)
RATE_LIMIT=60

# Hard per-request render timeout in ms (default: 30000)
RENDER_CEILING_MS=30000

# Max concurrent Playwright renders (default: min(4, CPUs)); excess requests queue
RENDER_CONCURRENCY=4

# Age in ms before returnType=url files in /output are swept (default: 24h)
OUTPUT_TTL_MS=86400000

# Absolute public origin for /output image URLs (so Metricool can fetch them).
# Leave blank to use the request host. e.g. https://shots.example.com
PUBLIC_BASE_URL=

# Optional: blog IDs that must NEVER be posted to (comma-separated). Empty by
# default. Set this to any brand you want to make impossible to publish/draft to.
METRICOOL_BLOCKED_BLOG_IDS=

# Default timezone for Metricool publicationDate
METRICOOL_TZ=America/Chicago

# ── Direct Metricool publishing (POST /api/v1/publish) ──
# Required to schedule from the app itself. Metricool Advanced plan needed.
# Token: Metricool → Settings → API. userId from the same page / brand URL.
METRICOOL_USER_TOKEN=
METRICOOL_USER_ID=
# Optional overrides (defaults shown) in case Metricool's API path changes:
# METRICOOL_API_BASE=https://app.metricool.com/api
# METRICOOL_SCHEDULER_PATH=/v2/scheduler/posts

# ── Watchers (auto-follow accounts → auto-draft to Metricool) ──
# The in-app poller checks followed accounts and drafts new tweets. Requires a
# read-capable Twitter API tier (free tier read caps are very low — Basic+ recommended)
# and PUBLIC_BASE_URL set so Metricool can fetch the rendered images.
WATCH_ENABLED=true
WATCH_INTERVAL_MS=300000      # poll cadence (default 5 min; min 60s)
WATCH_MAX_PER_POLL=8          # max new conversations drafted per account per poll

# ── Review notifications (daily digest of new drafts) ──
# Webhook: Slack/Discord incoming-webhook URL, or any URL (gets structured JSON).
NOTIFY_WEBHOOK_URL=
# Email digest (SMTP):
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
NOTIFY_EMAIL_TO=
NOTIFY_EMAIL_FROM=
# Hour (0-23, server local time) to send the daily digest. Default 9am.
DIGEST_HOUR=9
# Link the digest points to for reviewing/scheduling:
METRICOOL_PLANNER_URL=https://app.metricool.com/planning
